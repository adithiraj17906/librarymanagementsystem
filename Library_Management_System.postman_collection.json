		{
			"name": "Borrow",
			"item": [
				{
					"name": "Borrow Book (User 1, Book 1)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Borrow status is BORROWED\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"BORROWED\");",
									"    pm.expect(jsonData.bookId).to.not.be.null;",
									"    pm.expect(jsonData.userId).to.not.be.null;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/borrow/1/1",
							"host": ["{{baseUrl}}"],
							"path": ["borrow", "1", "1"]
						}
					}
				},
